# ─── X (Twitter) API v2 ─────────────────────────────────────────────
# From developer.x.com → your Project/App. App permissions must be Read+Write.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# ─── Supabase ───────────────────────────────────────────────────────
# Use a project dedicated to this bot. Service-role key (server-side only).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ─── Telegram ───────────────────────────────────────────────────────
# Bot token from @BotFather. User ID (numeric) from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=

# ─── Behaviour ──────────────────────────────────────────────────────
# DRY_RUN=true logs what it WOULD post instead of calling the X API.
# Leave true until you've watched a real slot fire, then set false.
DRY_RUN=true

# IANA timezone for posting slots and the daily analytics job.
TIMEZONE=Asia/Singapore

# How far back (days) to refresh engagement on posted tweets.
METRICS_LOOKBACK_DAYS=7

# Randomize each posting slot forward by 0..N minutes so the cadence isn't robotic.
# e.g. with 30, the "08:00" slot posts somewhere in 08:00-08:30, different daily. 0 = off.
POSTING_JITTER_MINUTES=30
